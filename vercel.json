{
  "buildCommand": "cd frontend && npm install && npx tsc -b && npx vite build --outDir ../public",
  "functions": {
    "api/index.py": {
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
